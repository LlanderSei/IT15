@page
@model Record_Villacino.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
  ViewData["Title"] = "Forgot password";
}

<section class="identity-wrapper">
  <aside class="identity-panel">
    <span class="eyebrow bg-white text-dark">Password Help</span>
    <h1 class="display-6 fw-bold mt-3">Recover your account access.</h1>
    <p class="mt-3 mb-4">
      This page keeps the same visual style as Login and Register while giving users a clear path to reset credentials.
    </p>
    <ul class="identity-list">
      <li>Focused single-field form</li>
      <li>Bootstrap validation support</li>
      <li>Consistent branded layout for Identity pages</li>
    </ul>
  </aside>

  <div class="identity-card">
    <span class="eyebrow">Recovery Form</span>
    <h2 class="mt-3 mb-2">Forgot your password?</h2>
    <p class="text-secondary">Enter your email address and continue to the recovery flow.</p>

    <form method="post" data-loading-form="true">
      <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

      <div class="mb-4">
        <label asp-for="Input.Email" class="form-label" data-bs-toggle="tooltip" title="Enter the same email used during registration">
          <span class="form-icon">@@</span>Email Address
        </label>
        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
        <div class="field-hint mt-2">The system checks whether the account exists before continuing.</div>
        <span asp-validation-for="Input.Email" class="text-danger small"></span>
      </div>

      <button type="submit" class="btn btn-primary w-100 rounded-pill py-3" data-loading-button="true">
        <span class="spinner-border spinner-border-sm d-none me-2" aria-hidden="true"></span>
        <span data-button-text>Send Reset Link</span>
        <span data-loading-text class="d-none">Processing request...</span>
      </button>
    </form>
  </div>
</section>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
