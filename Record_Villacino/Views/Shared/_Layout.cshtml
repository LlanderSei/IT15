<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - Record_Villacino</title>
  <script type="importmap"></script>
  <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/Record_Villacino.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
  <header class="site-header">
    <nav class="navbar navbar-expand-lg">
      <div class="container">
        <a class="navbar-brand site-brand" asp-area="" asp-controller="Home" asp-action="Index">
          <span class="brand-mark">RV</span>
          <span>
            <strong>Record Villacino</strong>
            <small>Student activity portal</small>
          </span>
        </a>
        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav me-auto mb-3 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">About</a>
            </li>
            @if (User.Identity?.IsAuthenticated ?? false) {
              <li class="nav-item">
                <a class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index">Manage Account</a>
              </li>
            }
            @if (User.IsInRole("Admin")) {
              <li class="nav-item">
                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Admin Panel</a>
              </li>
            }
          </ul>
          <partial name="_LoginPartial" />
        </div>
      </div>
    </nav>
  </header>

  <main class="container py-4 py-lg-5">
    @RenderBody()
  </main>

  <footer class="site-footer">
    <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
      <span>&copy; 2026 Record_Villacino</span>
      <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
  </footer>
  <script src="~/lib/jquery/dist/jquery.min.js"></script>
  <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
  <script src="~/js/site.js" asp-append-version="true"></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
