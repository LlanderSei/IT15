@{
  ViewData["Title"] = "Home";
}

<section class="hero-card">
  <div class="row align-items-center g-4">
    <div class="col-lg-7">
      <span class="eyebrow">ASP.NET Core MVC Activity 4</span>
      <h1 class="display-5 fw-bold mt-3">Simple record portal with a customized Identity UI.</h1>
      <p class="lead text-secondary mt-3">
        This template was adjusted for the activity requirements: a cleaner homepage, a unique authentication layout,
        responsive forms, and navigation that changes based on user sign-in state.
      </p>
      <div class="d-flex flex-wrap gap-3 mt-4">
        <a class="btn btn-primary btn-lg rounded-pill px-4" asp-area="Identity" asp-page="/Account/Register">Create Account</a>
        <a class="btn btn-outline-secondary btn-lg rounded-pill px-4" asp-area="Identity" asp-page="/Account/Login">Sign In</a>
      </div>
    </div>
    <div class="col-lg-5">
      <div class="summary-panel">
        <div class="summary-item">
          <span class="summary-badge">01</span>
          <div>
            <h2>Responsive</h2>
            <p>Bootstrap-styled forms with validation feedback and mobile-friendly layout.</p>
          </div>
        </div>
        <div class="summary-item">
          <span class="summary-badge">02</span>
          <div>
            <h2>Identity Ready</h2>
            <p>Login, Register, Forgot Password, and profile pages use a dedicated interface.</p>
          </div>
        </div>
        <div class="summary-item">
          <span class="summary-badge">03</span>
          <div>
            <h2>Dynamic Nav</h2>
            <p>Guests see auth links while signed-in users get account management actions.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
